# --- Database ---
DATABASE_URL=postgresql+asyncpg://cabinet_user:cabinet_pass@localhost:5432/cabinet_inventory
DATABASE_URL_SYNC=postgresql+psycopg2://cabinet_user:cabinet_pass@localhost:5432/cabinet_inventory

# --- Auth ---
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=random-secret-for-webhook-url
TELEGRAM_COORDINATOR_CHAT_ID=-100xxxxxxxxxx

# --- App ---
APP_NAME=Cabinet Inventory
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Sentry (optional, leave blank to disable) ---
SENTRY_DSN=
